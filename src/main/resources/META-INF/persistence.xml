<?xml version="1.0" encoding="UTF-8"?>
<persistence xmlns="http://xmlns.jcp.org/xml/ns/persistence" version="2.2">

    <persistence-unit name="GestionPU" transaction-type="RESOURCE_LOCAL">

        <class>com.gestion.models.Employe</class>
        <class>com.gestion.models.Projet</class>
        <class>com.gestion.models.Categorie</class>
        <class>com.gestion.models.Affectation</class>

        <properties>
            <property name="javax.persistence.jdbc.driver"
                      value="com.mysql.cj.jdbc.Driver"/>
            <!-- Valeurs fallback locales — remplacées par JPAUtil depuis les env vars -->
            <property name="javax.persistence.jdbc.url"
                      value="jdbc:mysql://localhost:3306/gestion_projets?serverTimezone=UTC&amp;useSSL=false"/>
            <property name="javax.persistence.jdbc.user"     value="root"/>
            <property name="javax.persistence.jdbc.password" value=""/>

            <property name="hibernate.dialect"
                      value="org.hibernate.dialect.MySQL8Dialect"/>
            <property name="hibernate.show_sql"    value="false"/>
            <property name="hibernate.hbm2ddl.auto" value="update"/>
        </properties>

    </persistence-unit>
</persistence>
